{
  "name": "@ai-ds/core",
  "version": "0.3.0",
  "description": "AI Design System — reusable architectural core (tokens, contracts, scripts, components, hooks, Figma plugin)",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json",
    "./spec": "./ai-ds-spec.json",
    "./tokens": "./config/css-variables/tokens.css",
    "./tailwind": "./config/tailwind/tailwind.config.cjs",
    "./postcss": "./postcss.config.cjs",
    "./contracts/*": "./contracts/components/*.contract.json",
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./components/*": {
      "types": "./dist/components/primitives/*/index.d.ts",
      "default": "./dist/components/primitives/*/index.js"
    },
    "./icons": {
      "types": "./dist/components/icons/index.d.ts",
      "default": "./dist/components/icons/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "default": "./dist/hooks/*.js"
    },
    "./shared": {
      "types": "./dist/components/primitives/_shared/index.d.ts",
      "default": "./dist/components/primitives/_shared/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "default": "./dist/layout/index.js"
    },
    "./behaviors": {
      "types": "./dist/behaviors/index.d.ts",
      "default": "./dist/behaviors/index.js"
    },
    "./utils": {
      "types": "./dist/utils/token-resolver.d.ts",
      "default": "./dist/utils/token-resolver.js"
    },
    "./images/*": "./images/*",
    "./blocks-spec": "./blocks-spec.json",
    "./blocks": {
      "types": "./dist/components/blocks/index.d.ts",
      "default": "./dist/components/blocks/index.js"
    },
    "./blocks/*": {
      "types": "./dist/components/blocks/*/index.d.ts",
      "default": "./dist/components/blocks/*/index.js"
    },
    "./block-contracts/*": "./contracts/blocks/*.block-contract.json"
  },
  "files": [
    "dist/",
    "ai-ds-spec.json",
    "ai-ds-styles.json",
    "ai-ds-components.json",
    "ai-ds-blocks.json",
    "blocks-spec.json",
    "component-structures.json",
    "postcss.config.cjs",
    "config/",
    "contracts/",
    "images/"
  ],
  "scripts": {
    "tokens:build": "npx tsx scripts/spec-to-tokens.ts",
    "tokens:validate": "npx tsx scripts/validate-tokens.ts",
    "contracts:generate": "npx tsx scripts/spec-to-contracts.ts",
    "components:generate": "npx tsx scripts/spec-to-components.ts",
    "behaviors:generate": "npx tsx scripts/spec-to-behaviors.ts",
    "stories:generate": "npx tsx scripts/spec-to-stories.ts",
    "icons:generate": "npx tsx scripts/icons-to-components.ts",
    "structures:enrich": "npx tsx scripts/figma-to-structures.ts",
    "blocks:generate-contracts": "npx tsx scripts/spec-to-block-contracts.ts",
    "blocks:generate-components": "npx tsx scripts/spec-to-block-components.ts",
    "blocks:generate": "npm run blocks:generate-contracts && npm run blocks:generate-components",
    "spec:split": "npx tsx scripts/split-spec.ts",
    "spec:merge": "npx tsx scripts/merge-spec.ts",
    "spec:validate": "npx tsx scripts/validate-spec.ts",
    "spec:validate-styles": "npx tsx scripts/validate-spec.ts --styles-only",
    "spec:extract": "npx tsx scripts/extract-styles.ts",
    "validate": "npx tsx scripts/validate-pipeline.ts",
    "build": "npm run structures:enrich && npm run tokens:build && npm run contracts:generate && npm run components:generate && npm run behaviors:generate && npm run stories:generate && npm run blocks:generate && npm run validate",
    "build:dist": "npx tsx scripts/build-dist.ts",
    "release": "npx tsx scripts/release.ts",
    "publish-core": "npx tsx scripts/publish-core.ts",
    "prepublishOnly": "npm run build && npm run build:dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "tailwindcss": ">=3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "ai-ds",
    "figma",
    "tailwind",
    "contracts"
  ],
  "license": "MIT",
  "dependencies": {
    "tailwind-merge": "^3.5.0"
  }
}
