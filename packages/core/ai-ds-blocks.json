[
  {
    "name": "@Block/AppSidebar",
    "description": "Application sidebar with navigation items, optional header/footer sections. Dark theme by default.",
    "category": "navigation",
    "layout": "vertical",
    "sizing": {
      "width": 260,
      "height": "fill"
    },
    "padding": {
      "x": "space_12",
      "y": "space_16"
    },
    "gap": "space_8",
    "tokens": {
      "background": "color_bg_base",
      "elevation": "effect_elevation_1"
    },
    "dataTheme": "dark",
    "slots": [
      {
        "name": "navItems",
        "description": "Primary navigation tabs",
        "layout": "vertical",
        "gap": "space_8",
        "grow": true,
        "repeat": true,
        "component": "@UI/Tab",
        "defaultProps": {
          "appearance": "ghost",
          "size": "md"
        }
      },
      {
        "name": "infoCard",
        "description": "Optional info/help card",
        "optional": true,
        "component": "@UI/Card",
        "defaultProps": {
          "variant": "base",
          "size": "md"
        }
      },
      {
        "name": "footer",
        "description": "Footer with settings/branding",
        "layout": "vertical",
        "gap": "space_8",
        "optional": true
      }
    ]
  },
  {
    "name": "@Block/AppTopBar",
    "description": "Top application bar with controls, search, and user info section.",
    "category": "navigation",
    "layout": "horizontal",
    "sizing": {
      "width": "fill",
      "height": "hug"
    },
    "padding": {
      "x": "space_24",
      "y": "space_12"
    },
    "gap": "space_24",
    "minHeight": "space_72",
    "tokens": {
      "background": "color_surface_1",
      "borderBottom": "color_border_base"
    },
    "slots": [
      {
        "name": "controls",
        "description": "Left control area",
        "layout": "horizontal",
        "gap": "space_24",
        "optional": true
      },
      {
        "name": "search",
        "description": "Search input",
        "grow": true,
        "maxWidth": 424,
        "component": "@UI/Input",
        "optional": true
      },
      {
        "name": "actions",
        "description": "Right action buttons",
        "layout": "horizontal",
        "gap": "space_12",
        "align": "center",
        "optional": true
      }
    ]
  },
  {
    "name": "@Block/MetricCard",
    "description": "Dashboard metric card with title, icon, and multiple MetricRow entries.",
    "category": "data-display",
    "layout": "vertical",
    "sizing": {
      "width": "fill",
      "height": "hug"
    },
    "padding": "space_inset_l",
    "gap": "space_content_m",
    "tokens": {
      "background": "color_surface_1",
      "elevation": "effect_elevation_1",
      "borderRadius": "radius_medium"
    },
    "slots": [
      {
        "name": "header",
        "layout": "horizontal",
        "align": "center",
        "justify": "between",
        "gap": "space_content_m",
        "children": [
          {
            "name": "icon",
            "type": "icon",
            "optional": true
          },
          {
            "name": "title",
            "type": "text",
            "textStyle": "Text/Body/LG",
            "textColor": "color_text_primary",
            "fontWeight": "semibold"
          },
          {
            "name": "action",
            "type": "icon",
            "optional": true
          }
        ]
      },
      {
        "name": "metrics",
        "layout": "vertical",
        "repeat": true,
        "component": "@Block/MetricRow"
      },
      {
        "name": "footer",
        "optional": true
      }
    ]
  },
  {
    "name": "@Block/MetricRow",
    "description": "Single metric display: label, value, optional delta indicator, optional description. Supports sm (compact/mobile) and md (desktop) sizes.",
    "category": "data-display",
    "layout": "vertical",
    "sizing": {
      "width": "fill",
      "height": "hug"
    },
    "padding": "none",
    "gap": "space_2",
    "tokens": {},
    "variantProps": [
      "size"
    ],
    "variantAxes": {
      "size": [
        "sm",
        "md"
      ]
    },
    "variantRules": [
      {
        "when": {
          "size": "sm"
        },
        "style": {
          "gap": "space_2",
          "labelStyle": "Text/Caption/XS",
          "valueStyle": "Text/Body/Base",
          "deltaStyle": "Text/Caption/XS",
          "descriptionStyle": "Text/Caption/XS"
        }
      },
      {
        "when": {
          "size": "md"
        },
        "style": {
          "gap": "space_4",
          "labelStyle": "Text/Caption/Base",
          "valueStyle": "Text/Body/LG",
          "deltaStyle": "Text/Body/SM",
          "descriptionStyle": "Text/Body/SM"
        }
      }
    ],
    "responsiveRules": [
      {
        "breakpoint": "mobile",
        "defaultSize": "sm"
      },
      {
        "breakpoint": "desktop",
        "defaultSize": "md"
      }
    ],
    "slots": [
      {
        "name": "label",
        "type": "text",
        "textStyle": "Text/Caption/Base",
        "textColor": "color_text_muted"
      },
      {
        "name": "valueRow",
        "layout": "horizontal",
        "align": "baseline",
        "gap": "space_4",
        "children": [
          {
            "name": "value",
            "type": "text",
            "textStyle": "Text/Body/LG",
            "textColor": "color_brand_primary",
            "fontWeight": "semibold"
          },
          {
            "name": "delta",
            "type": "text",
            "textStyle": "Text/Caption/XS",
            "optional": true
          }
        ]
      },
      {
        "name": "description",
        "type": "text",
        "textStyle": "Text/Caption/XS",
        "textColor": "color_text_muted",
        "optional": true
      }
    ]
  },
  {
    "name": "@Block/FiltersSidebar",
    "description": "Sidebar with vertically stacked filter rows and action buttons.",
    "category": "forms",
    "layout": "vertical",
    "sizing": {
      "width": 260,
      "height": "fill"
    },
    "padding": {
      "x": "space_16",
      "y": "space_16"
    },
    "gap": "space_8",
    "tokens": {
      "background": "color_surface_1",
      "borderRight": "color_border_base"
    },
    "slots": [
      {
        "name": "header",
        "layout": "horizontal",
        "justify": "between",
        "align": "center",
        "optional": true
      },
      {
        "name": "filters",
        "layout": "vertical",
        "gap": "space_8",
        "grow": true,
        "repeat": true,
        "component": "@Block/FilterRow"
      },
      {
        "name": "actions",
        "layout": "horizontal",
        "gap": "space_8",
        "justify": "end",
        "optional": true
      }
    ]
  },
  {
    "name": "@Block/FilterRow",
    "description": "Single filter row: label + input/dropdown control.",
    "category": "forms",
    "layout": "vertical",
    "sizing": {
      "width": "fill",
      "height": "hug"
    },
    "padding": "none",
    "gap": "space_4",
    "tokens": {},
    "slots": [
      {
        "name": "label",
        "type": "text",
        "textStyle": "Text/Caption/XS",
        "textColor": "color_text_muted"
      },
      {
        "name": "control",
        "component": "@UI/Input"
      }
    ]
  },
  {
    "name": "@Block/ProductCard",
    "description": "Product/listing card with image, title, price, and metadata.",
    "category": "data-display",
    "layout": "vertical",
    "sizing": {
      "width": "fill",
      "height": "hug"
    },
    "padding": "none",
    "gap": "none",
    "tokens": {
      "background": "color_surface_1",
      "elevation": "effect_elevation_1",
      "borderRadius": "radius_medium"
    },
    "slots": [
      {
        "name": "image",
        "component": "@UI/Image",
        "aspectRatio": "16/10"
      },
      {
        "name": "content",
        "layout": "vertical",
        "padding": {
          "x": "space_12",
          "y": "space_12"
        },
        "gap": "space_4",
        "children": [
          {
            "name": "title",
            "type": "text",
            "textStyle": "Text/Body/Base",
            "textColor": "color_text_primary",
            "fontWeight": "semibold"
          },
          {
            "name": "price",
            "type": "text",
            "textStyle": "Text/Body/LG",
            "textColor": "color_brand_primary",
            "fontWeight": "semibold",
            "optional": true
          },
          {
            "name": "meta",
            "type": "text",
            "textStyle": "Text/Caption/XS",
            "textColor": "color_text_muted",
            "optional": true
          }
        ]
      }
    ]
  },
  {
    "name": "@Block/ChatInputBar",
    "description": "Chat message input bar with text input and action buttons.",
    "category": "forms",
    "layout": "horizontal",
    "sizing": {
      "width": "fill",
      "height": "hug"
    },
    "padding": {
      "x": "space_24",
      "y": "space_12"
    },
    "gap": "space_8",
    "tokens": {
      "borderTop": "color_border_base",
      "background": "color_surface_1"
    },
    "slots": [
      {
        "name": "attachButton",
        "component": "@UI/Button",
        "optional": true
      },
      {
        "name": "input",
        "grow": true,
        "component": "@UI/Input"
      },
      {
        "name": "sendButton",
        "component": "@UI/Button"
      }
    ]
  },
  {
    "name": "@Block/ProgressCard",
    "description": "Card with title and list of labelled progress bars with values.",
    "category": "data-display",
    "layout": "vertical",
    "sizing": {
      "width": "fill",
      "height": "hug"
    },
    "padding": "space_inset_l",
    "gap": "space_content_m",
    "tokens": {
      "background": "color_surface_1",
      "elevation": "effect_elevation_1",
      "borderRadius": "radius_medium"
    },
    "slots": [
      {
        "name": "header",
        "layout": "horizontal",
        "align": "center",
        "justify": "between",
        "children": [
          {
            "name": "title",
            "type": "text",
            "textStyle": "Text/Body/LG",
            "textColor": "color_text_primary",
            "fontWeight": "semibold"
          },
          {
            "name": "action",
            "type": "icon",
            "optional": true
          }
        ]
      },
      {
        "name": "items",
        "layout": "vertical",
        "gap": "space_content_m",
        "repeat": true
      }
    ]
  },
  {
    "name": "@Block/HeroBanner",
    "description": "Hero banner/carousel section with navigation arrows and centered content.",
    "category": "content",
    "layout": "horizontal",
    "sizing": {
      "width": "fill",
      "height": "hug"
    },
    "minHeight": "space_320",
    "padding": {
      "x": "space_24",
      "y": "space_48"
    },
    "gap": "space_24",
    "tokens": {
      "background": "color_surface_1",
      "borderRadius": "radius_large"
    },
    "slots": [
      {
        "name": "prevButton",
        "component": "@UI/Button",
        "optional": true
      },
      {
        "name": "content",
        "layout": "vertical",
        "align": "center",
        "grow": true,
        "gap": "space_8",
        "children": [
          {
            "name": "icon",
            "type": "icon",
            "optional": true
          },
          {
            "name": "title",
            "type": "text",
            "textStyle": "Text/Heading/H2",
            "textColor": "color_text_primary",
            "textAlign": "center"
          },
          {
            "name": "subtitle",
            "type": "text",
            "textStyle": "Text/Body/Base",
            "textColor": "color_text_muted",
            "textAlign": "center",
            "optional": true
          },
          {
            "name": "cta",
            "component": "@UI/Button",
            "optional": true
          }
        ]
      },
      {
        "name": "nextButton",
        "component": "@UI/Button",
        "optional": true
      }
    ]
  },
  {
    "name": "@Block/Navbar",
    "description": "Global top-level navigation bar: [Logo] [Nav?] [Search?] → [Bell] [Avatar] [Username ▾]. Supports default/compact density.",
    "category": "navigation",
    "layout": "horizontal",
    "sizing": {
      "width": "fill",
      "height": "hug"
    },
    "padding": {
      "x": "space_24",
      "y": "space_0"
    },
    "gap": "space_0",
    "tokens": {
      "background": "color_surface_1",
      "borderBottom": "color_border_base"
    },
    "variantProps": [
      "size"
    ],
    "variantAxes": {
      "size": [
        "default",
        "compact"
      ]
    },
    "variantRules": [
      {
        "when": {
          "size": "default"
        },
        "style": {
          "height": 64,
          "paddingY": "space_12",
          "logoHeight": 28,
          "navTextStyle": "Text/Body/Base",
          "navGap": "space_8",
          "actionGap": "space_12"
        }
      },
      {
        "when": {
          "size": "compact"
        },
        "style": {
          "height": 48,
          "paddingY": "space_8",
          "logoHeight": 24,
          "navTextStyle": "Text/Caption/Base",
          "navGap": "space_4",
          "actionGap": "space_8"
        }
      }
    ],
    "responsiveRules": [
      {
        "breakpoint": "desktop",
        "showNav": true,
        "showSearch": true,
        "showUsername": true
      },
      {
        "breakpoint": "tablet",
        "showNav": true,
        "showSearch": true,
        "showUsername": false
      },
      {
        "breakpoint": "mobile",
        "showNav": false,
        "showSearch": false,
        "showUsername": false
      }
    ],
    "slots": [
      {
        "name": "logo",
        "type": "composite",
        "description": "Aica icon + brand name text"
      },
      {
        "name": "nav",
        "layout": "horizontal",
        "gap": "space_8",
        "optional": true,
        "repeat": true,
        "component": "@UI/Link"
      },
      {
        "name": "search",
        "component": "@UI/Autocomplete",
        "optional": true
      },
      {
        "name": "notifications",
        "type": "icon-button",
        "icon": "bell"
      },
      {
        "name": "avatar",
        "component": "@UI/Avatar"
      },
      {
        "name": "userDropdown",
        "layout": "horizontal",
        "gap": "space_4",
        "description": "Username text + chevron-down icon, borderless dropdown trigger"
      }
    ]
  }
]
