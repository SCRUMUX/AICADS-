{
  "name": "@Block/MetricRow",
  "description": "Single metric display: label, value, optional delta indicator, optional description. Supports sm (compact/mobile) and md (desktop) sizes.",
  "category": "data-display",
  "layout": "vertical",
  "sizing": {
    "width": "fill",
    "height": "hug"
  },
  "tailwindClasses": [
    "flex",
    "flex-col",
    "flex-1",
    "min-w-0",
    "gap-[var(--space-2)]"
  ],
  "tokens": {},
  "slots": [
    {
      "name": "label",
      "type": "text",
      "textStyle": "Text/Caption/Base",
      "textColor": "color_text_muted"
    },
    {
      "name": "valueRow",
      "layout": "horizontal",
      "align": "baseline",
      "gap": "space_4",
      "children": [
        {
          "name": "value",
          "type": "text",
          "textStyle": "Text/Body/LG",
          "textColor": "color_brand_primary",
          "fontWeight": "semibold"
        },
        {
          "name": "delta",
          "type": "text",
          "textStyle": "Text/Caption/XS",
          "optional": true,
          "variants": {
            "positive": {
              "textColor": "color_success_base"
            },
            "negative": {
              "textColor": "color_danger_base"
            },
            "muted": {
              "textColor": "color_text_muted"
            }
          }
        }
      ]
    },
    {
      "name": "description",
      "type": "text",
      "textStyle": "Text/Caption/XS",
      "textColor": "color_text_muted",
      "optional": true
    }
  ],
  "dependencies": [],
  "padding": "none",
  "gap": "space_2",
  "responsiveRules": [
    {
      "breakpoint": "mobile",
      "defaultSize": "sm"
    },
    {
      "breakpoint": "desktop",
      "defaultSize": "md"
    }
  ]
}