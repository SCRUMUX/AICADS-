{
  "name": "@UI/Skeleton/Table",
  "description": "Skeleton / Table: шаблон-заглушка для таблицы. Структура: 1 header-строка (bg=color_surface_3) + 4 data-строки. 4 колонки с переменной шириной ячеек. Зеркалит размерный ряд @UI/Table. Оси: size (sm/md/lg) × shimmer (true/false).",
  "variantProps": [
    "size",
    "shimmer"
  ],
  "variantAxes": {
    "size": [
      "sm",
      "md",
      "lg"
    ],
    "shimmer": [
      "true",
      "false"
    ]
  },
  "variantRules": [
    {
      "when": {},
      "style": {
        "background": "color_bg_base",
        "headerBg": "color_surface_3",
        "blockColor": "color_surface_3",
        "shimmerHighlight": "color_surface_2",
        "dividerColor": "color_divider",
        "borderColor": "color_border_base",
        "borderRadius": "radius_medium",
        "paddingX": "space_table_cell_x_md",
        "paddingY": "space_table_cell_y_md",
        "rowH": "space_table_row_h_md",
        "lineH": "space_skeleton_line_h_md",
        "colCount": 4,
        "rowCount": 4,
        "colWidths": [
          0.15,
          0.35,
          0.25,
          0.25
        ],
        "cellLineWidths": [
          0.7,
          0.6,
          0.8,
          0.5
        ],
        "minWidth": "space_table_min_md"
      },
      "tailwindClasses": [
        "bg-[var(--color-bg-base)]",
        "[--divider-color:var(--color-divider)]",
        "border",
        "border-[var(--color-border-base)]",
        "px-[var(--space-table-cell-x-md)]",
        "py-[var(--space-table-cell-y-md)]",
        "min-w-[var(--space-table-min-md)]",
        "rounded-medium"
      ]
    },
    {
      "when": {
        "size": "sm"
      },
      "style": {
        "paddingX": "space_table_cell_x_sm",
        "paddingY": "space_table_cell_y_sm",
        "rowH": "space_table_row_h_sm",
        "lineH": "space_skeleton_line_h_sm",
        "minWidth": "space_table_min_sm"
      },
      "tailwindClasses": [
        "px-[var(--space-table-cell-x-sm)]",
        "py-[var(--space-table-cell-y-sm)]",
        "min-w-[var(--space-table-min-sm)]"
      ]
    },
    {
      "when": {
        "size": "md"
      },
      "style": {
        "paddingX": "space_table_cell_x_md",
        "paddingY": "space_table_cell_y_md",
        "rowH": "space_table_row_h_md",
        "lineH": "space_skeleton_line_h_md",
        "minWidth": "space_table_min_md"
      },
      "tailwindClasses": [
        "px-[var(--space-table-cell-x-md)]",
        "py-[var(--space-table-cell-y-md)]",
        "min-w-[var(--space-table-min-md)]"
      ]
    },
    {
      "when": {
        "size": "lg"
      },
      "style": {
        "paddingX": "space_table_cell_x_lg",
        "paddingY": "space_table_cell_y_lg",
        "rowH": "space_table_row_h_lg",
        "lineH": "space_skeleton_line_h_lg",
        "minWidth": "space_table_min_lg"
      },
      "tailwindClasses": [
        "px-[var(--space-table-cell-x-lg)]",
        "py-[var(--space-table-cell-y-lg)]",
        "min-w-[var(--space-table-min-lg)]"
      ]
    },
    {
      "when": {
        "shimmer": "true"
      },
      "style": {
        "shimmer": true
      },
      "tailwindClasses": [
        "[data-shimmer=\"true\"]"
      ]
    },
    {
      "when": {
        "shimmer": "false"
      },
      "style": {
        "shimmer": false
      },
      "tailwindClasses": [
        "[data-shimmer=\"false\"]"
      ]
    }
  ],
  "focusRing": "focus:outline-none focus:shadow-focus-brand",
  "focusRingDanger": "focus:outline-none focus:shadow-focus-danger",
  "responsiveProps": {
    "paddingX": {
      "sm": "space_table_cell_x_sm",
      "md": "space_table_cell_x_md",
      "lg": "space_table_cell_x_lg"
    },
    "paddingY": {
      "sm": "space_table_cell_y_sm",
      "md": "space_table_cell_y_md",
      "lg": "space_table_cell_y_lg"
    },
    "minWidth": {
      "sm": "space_table_min_sm",
      "md": "space_table_min_md",
      "lg": "space_table_min_lg"
    }
  },
  "element": "div",
  "rootLayout": "vertical",
  "rootSizing": {
    "main": "hug",
    "cross": "fixed"
  },
  "customStructure": "skeletonTable",
  "styleKeys": [
    "paddingX",
    "paddingY",
    "rowH",
    "lineH",
    "minWidth",
    "colCount",
    "rowCount",
    "blockColor",
    "background",
    "headerBg",
    "dividerColor",
    "borderColor",
    "borderRadius",
    "shimmer"
  ],
  "heightConstraint": "hug",
  "clipsContent": true,
  "generatorStrategy": "template",
  "template": "SkeletonTable"
}