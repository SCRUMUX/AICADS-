{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "layout-spec.schema.json",
  "title": "Layout Specification",
  "description": "Canonical format for machine-readable layout specifications. Describes UI structure using token-driven intents.",
  "type": "object",
  "required": ["type", "name", "root"],
  "properties": {
    "type": {
      "type": "string",
      "const": "layout",
      "description": "Must be 'layout'"
    },
    "name": {
      "type": "string",
      "description": "Human-readable layout name (e.g. 'DashboardPage')"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of this spec"
    },
    "root": {
      "$ref": "#/definitions/LayoutNode"
    }
  },
  "definitions": {
    "LayoutNode": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier within the spec"
        },
        "type": {
          "type": "string",
          "enum": ["container", "grid-item", "spacer"],
          "description": "Node type"
        },
        "container": {
          "$ref": "#/definitions/ContainerConfig"
        },
        "grid": {
          "$ref": "#/definitions/GridPlacement"
        },
        "spacing": {
          "$ref": "#/definitions/SpacingConfig"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/LayoutNode"
          }
        },
        "componentRef": {
          "type": "string",
          "description": "Reference to a component type for dynamic rendering"
        },
        "behaviorId": {
          "type": "string",
          "description": "Reference to a behavior in the Behavior Registry (shorthand for click behavior)"
        },
        "behaviors": {
          "type": "object",
          "description": "Event-specific behavior mappings. Keys are event names, values are behavior IDs from the registry.",
          "properties": {
            "click":  { "type": "string" },
            "hover":  { "type": "string" },
            "focus":  { "type": "string" },
            "submit": { "type": "string" },
            "change": { "type": "string" }
          },
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "ContainerConfig": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["page", "section", "card", "panel", "modal", "content"],
          "description": "Container semantic type"
        },
        "variant": {
          "type": "string",
          "enum": ["default", "elevated", "bordered", "transparent"],
          "description": "Visual variant"
        },
        "padding": {
          "$ref": "#/definitions/SpacingIntent"
        },
        "radius": {
          "type": "string",
          "enum": ["none", "subtle", "default", "medium", "large", "xl", "pill"],
          "description": "Border radius token name"
        },
        "elevation": {
          "type": "string",
          "enum": ["none", "1", "2", "3", "glow"],
          "description": "Elevation token name"
        },
        "background": {
          "type": "string",
          "enum": ["base", "muted", "surface-1", "surface-2", "surface-3", "disabled", "brand-muted", "transparent"],
          "description": "Background color token"
        },
        "border": {
          "type": "boolean",
          "description": "Whether to show border"
        },
        "maxWidth": {
          "type": "string",
          "description": "Max width constraint"
        }
      }
    },
    "GridPlacement": {
      "type": "object",
      "description": "Grid placement within a parent grid container. Spans define how many columns this node occupies.",
      "properties": {
        "spans": {
          "$ref": "#/definitions/ResponsiveValue"
        },
        "alignment": {
          "type": "string",
          "enum": ["start", "center", "end", "stretch"]
        }
      }
    },
    "SpacingConfig": {
      "type": "object",
      "properties": {
        "margin": {
          "$ref": "#/definitions/SpacingIntent"
        },
        "padding": {
          "$ref": "#/definitions/SpacingIntent"
        },
        "gap": {
          "$ref": "#/definitions/SpacingIntent"
        }
      }
    },
    "SpacingIntent": {
      "type": "object",
      "required": ["category", "size"],
      "properties": {
        "category": {
          "type": "string",
          "enum": ["layout", "content", "control", "inset"]
        },
        "size": {
          "type": "string",
          "enum": ["xs", "s", "m", "l", "xl"]
        },
        "side": {
          "type": "string",
          "enum": ["top", "right", "bottom", "left", "x", "y", "all"],
          "default": "all"
        }
      }
    },
    "ResponsiveValue": {
      "type": "object",
      "description": "Per-breakpoint grid span values. Maximums match Layout.contract.json column counts.",
      "properties": {
        "mobile": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "tablet": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "desktop": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        }
      }
    }
  }
}
